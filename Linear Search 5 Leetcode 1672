class Solution {
    public int maximumWealth(int[][] accounts) {

        int[] nums = new int[accounts.length];

        for(int i = 0; i < accounts.length; i++) {
            for(int j = 0; j < accounts[i].length; j++) {
                nums[i] += accounts[i][j];
            }
        }

        int key = nums[0];

        for(int k = 1; k < nums.length; k++) {
            if(key < nums[k]) {
                key = nums[k];
            }
        }

        return key;
    }
}
